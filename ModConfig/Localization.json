        "fa3e1f7d4e3347bdaeb88a1b6c8baab6": {
            "enGB": "« I have work to entrust to your craftsmen. »",
            "frFR": "« J'ai du travail à confier à vos artisans. »",
            "ruRU": "«У меня есть работа, которую я хочу доверить вашим мастерам.»"
        },
        "storyteller_wilcer_contact_key": {
            "enGB": "« I would like you to contact Quartermaster Wilcer Garms for me. »",
            "frFR": "« Je souhaiterais que vous contactiez le quartier-maître Wilcer Garms pour moi. »",
            "ruRU": "«Я бы хотел, чтобы вы связались с интендантом Уилцером Гармсом для меня.»"
        },
        "storyteller_wilcer_reply_key": {
            "enGB": "« Yes, I think I know who that is. What would you like me to tell him? »",
            "frFR": "« Oui, je pense savoir de qui il s'agit. Que voulez-vous que je lui transmette ? »",
            "ruRU": "«Да, я кажется знаю, кто это. Что вы хотите, чтобы я ему передал?»"
        },
        "storyteller_wilcer_workshop_key": {
            "enGB": "« It's about an item from his workshop. »",
            "frFR": "« C'est à propos d'un objet de son atelier. »",
            "ruRU": "«Это насчет предмета из его мастерской.»"
        },
        "storyteller_wilcer_enchant_key": {
            "enGB": "« I would like him to have a piece of equipment enchanted. »",
            "frFR": "« Je voudrais qu'il fasse enchanter une pièce d'équipement »",
            "ruRU": "«Я бы хотел, чтобы он зачаровал часть снаряжения.»"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab7": {
            "enGB": "« Of course, the Quartermaster's office is here for that. What is it about exactly? »",
            "frFR": "« Bien sûr, l'Intendance est là pour ça. De quoi s'agit-il précisément ? »",
            "ruRU": "«Разумеется, интендантская служба для того и существует. В чем именно заключается ваш вопрос?»"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab8": {
            "enGB": "« Here is some equipment they should take care of. »",
            "frFR": "« Voici un équipement dont ils doivent s'occuper. »",
            "ruRU": "«Вот снаряжение, о котором им следует позаботиться.»"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab9": {
            "enGB": "« I would like to modify some equipment I already entrusted to you. »",
            "frFR": "« J'aimerais modifier un équipement que je vous ai confié. »",
            "ruRU": "«Я бы хотел улучшить вещи, которое уже передал вам.»"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab1": {
            "enGB": "« Forget about it. »",
            "frFR": "« Oubliez ça. »",
            "ruRU": "«Забудьте об этом. »"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab2": {
            "enGB": "« I'm listening. Show me the equipment in question, I'll see that it's sent to the best specialists in Mendev. »",
            "frFR": "« Je vous écoute. Montrez-moi l'équipement en question, je m'occuperai de le transmettre aux meilleurs spécialistes du Mendev. »",
            "ruRU": "«Я слушаю. Покажите мне это вещи, я прослежу, чтобы его отправили к лучшим специалистам в Мендев.»"
        },
        "dialog_cue_stored_item": {
            "enGB": "« Very well, let's take a look at your stash. What enchants do you want on those items? »",
            "frFR": "« Très bien, inspectons votre réserve. Quels enchantements souhaitez-vous appliquer à ces objets ? »",
            "ruRU": "«Что ж, давайте взглянем на ваши запасы. Какие чары вы хотите наложить на эти предметы?.»"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab3": {
            "enGB": "« As you wish. Anything else? »",
            "frFR": "« Entendu. Je reste à votre disposition si vous changez d'avis. Autre chose ? »",
            "ruRU": "«Как пожелаете. Что-нибудь еще? »"
        },
