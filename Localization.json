{
    "strings": {
        "fa3e1f7d4e3347bdaeb88a1b6c8baab6": {
            "enGB": "« I have work to entrust to your craftsmen. »",
            "frFR": "« J'ai du travail à confier à vos artisans. »"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab7": {
            "enGB": "« Of course, the Quartermaster's office is here for that. What is it about exactly? »",
            "frFR": "« Bien sûr, l'Intendance est là pour ça. De quoi s'agit-il précisément ? »"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab8": {
            "enGB": "« Here is some equipment they should take care of. »",
            "frFR": "« Voici un équipement dont ils doivent s'occuper. »"
        },
        "fa3e1f7d4e3347bdaeb88a1b6c8baab9": {
            "enGB": "« I would like to modify some equipment I already entrusted to you. »",
            "frFR": "« J'aimerais modifier un équipement que je vous ai confié. »"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab1": {
            "enGB": "« Forget about it. »",
            "frFR": "« Oubliez ça. »"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab2": {
            "enGB": "« I'm listening. Show me the equipment in question, I'll see that it's sent to the best specialists in Mendev. »",
            "frFR": "« Je vous écoute. Montrez-moi l'équipement en question, je m'occuperai de le transmettre aux meilleurs spécialistes du Mendev. »"
        },
        "dialog_cue_stored_item": {
            "enGB": "« Very well, let's take a look at your stash. What enchants do you want on those items? »",
            "frFR": "« Très bien, inspectons votre réserve. Quels enchantements souhaitez-vous appliquer à ces objets ? »"
        },
        "fa3e1f7d4e3347bdaeba8a1b6c8baab3": {
            "enGB": "« As you wish. Anything else? »",
            "frFR": "« Entendu. Je reste à votre disposition si vous changez d'avis. Autre chose ? »"
        },
